#. Plugin Name of the plugin
#: external-files-from-aws-s3.php
msgid "External files from AWS S3-compatible platforms in Media Library"
msgstr "Externe Dateien aus AWS S3-kompatiblen Plattformen in der Mediathek"

#. Description of the plugin
#: external-files-from-aws-s3.php
msgid ""
"Extends External files in Media Library for usage AWS S3-compatible "
"platforms."
msgstr ""
"Erweitert externe Dateien in der Mediathek für die Verwendung von AWS S3-"
"kompatiblen Plattformen."

#. Author of the plugin
#: external-files-from-aws-s3.php
msgid "Thomas Zwirner"
msgstr "Thomas Zwirner"

#. Author URI of the plugin
#: external-files-from-aws-s3.php
msgid "https://www.thomaszwirner.de"
msgstr "https://www.thomaszwirner.de"

